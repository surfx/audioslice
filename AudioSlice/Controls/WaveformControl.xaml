<UserControl x:Class="AudioSlice.Controls.WaveformControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="200" MouseLeftButtonDown="OnMouseLeftButtonDown" 
             MouseLeftButtonUp="OnMouseLeftButtonUp" MouseMove="OnMouseMove">
    <Grid Background="#0F2040" ClipToBounds="True">
        <Canvas x:Name="WaveformCanvas">
            <Polyline x:Name="WaveformPolyline" Stroke="#23FFAD" StrokeThickness="1" VerticalAlignment="Center" />
        </Canvas>
        
        <Canvas>
            <!-- Esquerda (Escurecido) - Mantemos sem clique para não atrapalhar o arraste -->
            <Rectangle x:Name="LeftDimmer" Fill="#000" Opacity="0.5" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" IsHitTestVisible="False"/>
            
            <!-- Direita (Escurecido) -->
            <Rectangle x:Name="RightDimmer" Fill="#000" Opacity="0.5" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" IsHitTestVisible="False"/>

            <!-- Handle Esquerdo -->
            <Canvas x:Name="LeftHandleGroup" Cursor="SizeWE">
                <Border Background="#23FFAD" Width="10" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" CornerRadius="2">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Padding="5,2" Canvas.Top="-30" Canvas.Left="-20">
                    <TextBlock Text="{Binding StartTimeStr, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="Black" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Canvas>

            <!-- Handle Direito -->
            <Canvas x:Name="RightHandleGroup" Cursor="SizeWE">
                <Border Background="#23FFAD" Width="10" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" CornerRadius="2">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                        <Ellipse Fill="#0A1428" Width="2" Height="2" Margin="0,2"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Padding="5,2" Canvas.Top="-30" Canvas.Left="-20">
                    <TextBlock Text="{Binding EndTimeStr, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="Black" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Canvas>
        </Canvas>
    </Grid>
</UserControl>
