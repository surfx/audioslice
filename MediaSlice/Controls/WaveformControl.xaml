<UserControl x:Class="MediaSlice.Controls.WaveformControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid Background="Transparent" ClipToBounds="True">
        <!-- O fundo da waveform (gráfico sólido) -->
        <Path x:Name="WaveformPath" Fill="#23FFAD" VerticalAlignment="Center" IsHitTestVisible="False"/>
        
        <!-- Área de Preview/Click -->
        <Canvas x:Name="ClickCanvas" Background="Transparent" MouseLeftButtonDown="OnMouseLeftButtonDown"/>
        
        <!-- Sobreposição de Seleção (Sem alças, apenas sombras) -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="LeftDimmer" Fill="#0A1428" Opacity="0.7" Height="2000"/>
            <Rectangle x:Name="RightDimmer" Fill="#0A1428" Opacity="0.7" Height="2000"/>
            
            <!-- Linhas finas apenas para marcar onde está o corte -->
            <Rectangle x:Name="LeftMarker" Fill="#23FFAD" Width="1" Height="2000" Opacity="0.5"/>
            <Rectangle x:Name="RightMarker" Fill="#23FFAD" Width="1" Height="2000" Opacity="0.5"/>
        </Canvas>
    </Grid>
</UserControl>
