<UserControl x:Class="MediaSlice.Controls.WaveformControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseLeftButtonDown="OnMouseLeftButtonDown"
             MouseLeftButtonUp="OnMouseLeftButtonUp"
             MouseMove="OnMouseMove">
    <Grid Background="Transparent" ClipToBounds="True">
        <Path x:Name="WaveformPath" Fill="#23FFAD" VerticalAlignment="Center" IsHitTestVisible="False"/>
        
        <Canvas x:Name="ClickCanvas" Background="Transparent" IsHitTestVisible="True"/>
        
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="LeftDimmer" Fill="#0A1428" Opacity="0.7" Height="2000"/>
            <Rectangle x:Name="RightDimmer" Fill="#0A1428" Opacity="0.7" Height="2000"/>
            
            <!-- Cursor de Progresso (Fica atrás das alças) -->
            <Rectangle x:Name="ProgressMarker" Fill="White" Width="2" Height="2000" Opacity="0.8" Visibility="Collapsed"/>
        </Canvas>

        <!-- ALÇAS DE ARRASTE (HANDLES) - Camada Superior para interação -->
        <Canvas x:Name="HandleCanvas">
            <Grid x:Name="LeftMarker" Width="12" Height="2000" Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="OnMarkerDown">
                <Rectangle Fill="#23FFAD" Width="4" HorizontalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="RightMarker" Width="12" Height="2000" Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="OnMarkerDown">
                <Rectangle Fill="#23FFAD" Width="4" HorizontalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                    <Ellipse Width="2" Height="2" Fill="#0A1428" Margin="0,2"/>
                </StackPanel>
            </Grid>
        </Canvas>
    </Grid>
</UserControl>
